GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

NEXT_PUBLIC_SUPABASE_URL=
# Use the publishable key if your Supabase dashboard shows one.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Or use the legacy anon public key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Use either server-only key name. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_PROMPT_COUNT_TIME_ZONE=Asia/Kolkata

# Admin panel (/admin) — the password you type to log in.
ADMIN_PANEL_PASSWORD=
# Optional: secret used to sign the admin session cookie. Falls back to ADMIN_PANEL_PASSWORD.
ADMIN_COOKIE_SECRET=

# NOTE: GEMINI_API_KEY_1..5 above are now only a FALLBACK. Once you add keys in the
# admin panel they take over automatically — no redeploy needed.
